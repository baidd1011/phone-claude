phone-claude.example.com {
  encode zstd gzip

  root * /opt/phone-claude/apps/mobile/dist

  handle /api/* {
    reverse_proxy 127.0.0.1:8787
  }

  handle /ws {
    reverse_proxy 127.0.0.1:8787
  }

  handle /health {
    reverse_proxy 127.0.0.1:8787
  }

  handle {
    try_files {path} /index.html
    file_server
  }
}
